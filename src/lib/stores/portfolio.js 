// Fetch function
export async function fetchPortfolioData() {
    try {
        const res = await fetch(`${DB_CONFIG.URL}/rest/v1/portfolio_metadata?category=eq.master_data&select=content`, {
            method: 'GET',
            headers: {
                'apikey': DB_CONFIG.KEY,
                'Authorization': `Bearer ${DB_CONFIG.KEY}`,
                'Content-Type': 'application/json'
            }
        });

        if (!res.ok) throw new Error('Network response not ok');

        const data = await res.json();
        if (data && data.length > 0) {
            const masterJson = data[0].content;
            localStorage.setItem('portfolio_master_data', JSON.stringify(masterJson));
            portfolioData.set(masterJson);
        }
    } catch (err) {
        console.error('Fetch failed:', err);
        const cached = JSON.parse(localStorage.getItem('portfolio_master_data'));
        portfolioData.set(cached);
    }
}

// Auto-fetch
fetchPortfolioData();